@page
@model Sablou_Web.Pages.Kurve.KurvModel
@using Sablou_Web.Pages.BrugerLogin
@using System.Globalization
@{
    ViewData["Title"] = "Din kurv";
}

<div class="container py-5">
    <h2 class="mb-4">🛒 @(LoginModel.CurrentBruger != null ? $"{LoginModel.CurrentBruger.Navn}s kurv" : "Gæstekurv")</h2>

    @if (!Model.KurvLinjer.Any())
    {
        <p class="text-muted">Din kurv er tom. <a asp-page="/VoresChokolader">Se vores chokolader</a></p>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                @foreach (var linje in Model.KurvLinjer)
                {
                    <div class="card shadow-sm mb-3">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="flex-grow-1">
                                <h5 class="mb-1">@linje.Navn</h5>
                                <small class="text-muted">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", linje.Stykpris) stk.</small>
                            </div>
                            <span class="fw-bold">Antal: @linje.Antal</span>
                            <div class="fw-bold">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", linje.Subtotal)</div>
                            <form method="post" asp-page-handler="Fjern">
                                <input type="hidden" name="chokoladeId" value="@linje.ChokoladeId" />
                                <button type="submit" class="btn btn-link text-danger p-0">✕</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Ordreoversigt</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span>@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", Model.Total)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Fragt</span>
                            <span>39,00 kr</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span>@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", Model.Total + 39)</span>
                        </div>
                        <a href="#" class="btn btn-dark w-100">Gå til betaling</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>