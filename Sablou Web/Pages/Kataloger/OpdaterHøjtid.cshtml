@page
@model Sablou_Web.Pages.Kataloger.OpdaterHøjtidModel
@using Sablou_Web.Models
@{
    ViewData["Title"] = "Opdater højtid";
}

<style>
    .vh-wrap {
        font-family: 'Poiret One', cursive;
        background: #faf7f2;
        padding: 0;
        margin: -1rem;
    }

    .vh-hero {
        background: #3d1f0d;
        color: #f5e6d3;
        padding: 2.5rem 2rem 2rem;
        text-align: center;
        border-bottom: 3px solid #8B4513;
        position: relative;
        overflow: hidden;
    }

        .vh-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient( 45deg, transparent, transparent 30px, rgba(139, 69, 19, 0.08) 30px, rgba(139, 69, 19, 0.08) 31px );
        }

    .vh-hero-inner {
        position: relative;
        z-index: 1;
    }

    .vh-hero-brand {
        font-family: 'Poiret one', cursive;
        font-size: 1.5rem;
        color: #d4956a;
        letter-spacing: 1px;
        margin-bottom: 0.25rem;
    }

    .vh-hero h1 {
        font-size: 2rem;
        margin: 0 0 0.4rem;
        font-weight: 400;
        letter-spacing: 2px;
    }

    .vh-hero p {
        font-size: 0.95rem;
        color: #d4956a;
        margin: 0;
        font-family: sans-serif;
        font-style: italic;
    }

    .vh-intro {
        background: #fff;
        border-bottom: 1px solid #e8ddd0;
        padding: 1.25rem 2rem;
        text-align: center;
        color: #666;
        font-family: sans-serif;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .vh-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
        padding: 1.5rem;
    }

    .vh-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e0d0c0;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .vh-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(61, 31, 13, 0.12);
        }

    .vh-card-top {
        padding: 1.5rem 1.25rem 1rem;
        text-align: center;
        border-bottom: 1px solid #f0e4d4;
    }

    .vh-icon {
        width: 52px;
        height: 52px;
        background: #faf0e8;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.75rem;
        font-size: 1.6rem;
        border: 2px solid #e8d0b8;
    }

    .vh-card-top h2 {
        font-family: 'Poiret One', cursive;
        font-size: 1.3rem;
        font-weight: 400;
        color: #3d1f0d;
        margin: 0 0 0.2rem;
        letter-spacing: 1.5px;
    }

    .vh-season {
        font-size: 0.75rem;
        color: #a07050;
        font-family: sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .vh-card-body {
        padding: 8% 10% 10%;
    }

        .vh-card-body p {
            font-family: sans-serif;
            font-size: 0.85rem;
            color: #666;
            line-height: 1.6;
            margin: 0 0 8%;
        }

    .vh-btn {
        display: block;
        width: 100%;
        padding: 0.55rem 1rem;
        background: #3d1f0d;
        color: #f5e6d3;
        border: none;
        border-radius: 6px;
        font-family: 'Poiret One', cursive;
        font-size: 0.95rem;
        letter-spacing: 1px;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: background 0.2s ease;
        box-sizing: border-box;
    }

    .vh-btn-påske {
        background: #fff7ea;
        color: #3d1f0d;
    }

    .vh-btn-morsDag {
        background: #fff1f6;
        color: #7f2f50;
    }

    .vh-btn-farsDag {
        background: #eff6fb;
        color: #16324f;
    }

    .vh-btn-halloween {
        background: #fff7ea;
        color: #EB6123;
    }

    .vh-btn:hover {
        background: #8B4513;
        color: #fff;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .vh-hero h1 {
            font-size: 1.5rem;
        }

        .vh-grid {
            grid-template-columns: 1fr;
            padding: 1rem;
        }
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center mb-4">
        <div class="col-12 col-lg-10">
            <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3">
                <div>
                    <h1 class="h3 mb-2">Opdater højtid</h1>
                    <p class="text-muted mb-0">Vælg et katalog og rediger det direkte herfra.</p>
                </div>
            </div>
        </div>
    </div>

    <form method="post">
        <div class="row g-4">
            @foreach (var katalog in Model.Repositories.HøjtidsKatalogRepository.Data.Values)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="vh-card-body d-flex flex-column p-4">
                            <h5 class="card-title mb-2">@katalog.Højtidsnavn</h5>
                            <p class="card-text text-muted flex-grow-1 mb-4">
                                Rediger indstillinger og oplysninger for dette katalog.
                            </p>

                            <div class="mt-auto">
                                <a class="vh-btn btn-primary w-100 rounded-pill"
                                   asp-page="/Kataloger/RedigerKatalog"
                                   asp-route-id="@katalog.Id">
                                    Rediger
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </form>
</div>