@page
@model Sablou_Web.Pages.Kataloger.HalloweenKatalogModel
@using Sablou_Web.Models
@{
}
<style>
    .catalog-wrap {
        font-family: 'Poiret One', cursive;
        background: #faf7f2;
        padding: 0 0 2rem;
        margin: -1rem;
    }

    .catalog-hero {
        background: linear-gradient(135deg, #E66C2C, #F4831B);
        color: #000000;
        padding: 2.5rem 2rem 2rem;
        text-align: center;
        border-bottom: 3px solid #d39c59;
        position: relative;
        overflow: hidden;
    }

        .catalog-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient( 45deg, transparent, transparent 30px, rgba(255, 255, 255, 0.06) 30px, rgba(255, 255, 255, 0.06) 31px );
        }

    .catalog-hero-inner {
        position: relative;
        z-index: 1;
    }

    .catalog-brand {
        font-family: 'Poiret One', cursive;
        font-size: 1.5rem;
        color: #000000;
        letter-spacing: 1px;
        margin-bottom: 0.25rem;
    }

    .catalog-hero h1 {
        font-size: 2rem;
        margin: 0 0 0.4rem;
        font-weight: 400;
        letter-spacing: 2px;
    }

    .catalog-hero p {
        font-size: 0.95rem;
        color: #000000;
        margin: 0;
        font-family: sans-serif;
        font-style: italic;
    }

    .catalog-intro {
        background: #fff;
        border-bottom: 1px solid #e8ddd0;
        padding: 1.25rem 2rem;
        text-align: center;
        color: #666;
        font-family: sans-serif;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .cart-feedback {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1rem 2rem 0;
        padding: 0.9rem 1rem;
        border-radius: 14px;
        background: linear-gradient(135deg, #e8fff1, #d9fbe8);
        color: #14532d;
        border: 1px solid #86efac;
        box-shadow: 0 8px 20px rgba(20, 83, 45, 0.12);
        font-weight: 600;
        font-family: sans-serif;
    }

    .cart-feedback-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #16a34a;
        color: white;
        flex: 0 0 auto;
    }

    .cart-feedback-text {
        flex: 1;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
        padding: 1.5rem;
        align-items: stretch;
    }

    .product {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e0d0c0;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(44, 18, 61, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .product:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(44, 18, 61, 0.12);
        }

    .product-top {
        padding: 1.25rem 1.25rem 1rem;
        text-align: center;
        border-bottom: 1px solid #f0e4d4;
    }

    .image-placeholder {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, #ffffff, #ffffff);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        color: #E66C2C;
        font-family: sans-serif;
        font-size: 0.9rem;
    }

    .product-top h3 {
        font-family: 'Poiret One', cursive;
        font-size: 1.3rem;
        font-weight: 400;
        color: #E66C2C;
        margin: 0 0 0.2rem;
        letter-spacing: 1.5px;
    }

    .product-top p {
        font-family: sans-serif;
        font-size: 0.85rem;
        color: #666;
        line-height: 1.6;
        margin: 0 0 0.75rem;
    }

    .product-price {
        color: #F4831B;
        margin-bottom: 0;
    }

    .product-actions {
        padding: 1rem 1.25rem 1.25rem;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

        .product-actions a,
        .product-actions form {
            flex: 1 1 10rem;
        }

    .product-btn {
        width: 100%;
        padding: 0.6rem 1rem;
        border-radius: 999px;
        font-family: 'Poiret One', cursive;
        font-size: 0.95rem;
        letter-spacing: 1px;
        border: none;
        text-align: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        box-sizing: border-box;
        text-decoration: none;
    }

        .product-btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

    .details-btn {
        background: #ffffff;
        color: #EB6123;
        border: 1px solid #EB6123;
        box-shadow: 0 4px 12px rgba(44, 18, 61, 0.08);
    }

        .details-btn:hover {
            color: #EB6123;
            text-decoration: none;
            box-shadow: 0 8px 18px rgba(44, 18, 61, 0.12);
        }

    .cart-btn {
        background: #EB6123;
        color: #f3e8fb;
        box-shadow: 0 4px 12px rgba(44, 18, 61, 0.18);
    }

        .cart-btn:hover {
            color: #fff;
            box-shadow: 0 8px 18px rgba(44, 18, 61, 0.24);
        }

    @@media (max-width: 768px) {
        .catalog-hero h1 {
            font-size: 1.5rem;
        }

        .product-grid {
            grid-template-columns: 1fr;
            padding: 1rem;
        }

        .catalog-intro,
        .cart-feedback {
            margin-left: 1rem;
            margin-right: 1rem;
        }
    }
</style>

<div class="catalog-wrap">

    <div class="catalog-hero">
        <div class="catalog-hero-inner">
            <div class="catalog-brand">Sabloú</div>
            <h1>Halloween</h1>
            <p>Mørke, mystiske og eventyrlige chokolader til årets mest gyselige aften</p>
        </div>
    </div>

    <div class="catalog-intro">
        Udforsk vores Halloween-sortiment med dybe farver, intense smage og stemningsfulde detaljer.
    </div>

    @{
        var cartFeedback = TempData["CartFeedback"] as string;
    }

    @if (!string.IsNullOrWhiteSpace(cartFeedback))
    {
        <div class="cart-feedback" role="status" aria-live="polite">
            <span class="cart-feedback-icon">✓</span>
            <span class="cart-feedback-text">@cartFeedback</span>
        </div>
    }

    <div class="product-grid">

        @foreach (var c in Model.Chokolader)
        {
            <div class="product">

                <div class="product-top">
                    @{
                        var chokoladeNavn = c?.Navn?.ToLowerInvariant() ?? string.Empty;
                        string? billedeUrl = null;

                        if (chokoladeNavn.Contains("sommer"))
                        {
                            billedeUrl = Url.Content("~/Images/Sommerchokolade.png");
                        }
                        else if (chokoladeNavn.Contains("jul"))
                        {
                            billedeUrl = Url.Content("~/Images/Julechokolade.png");
                        }
                        else if (chokoladeNavn.Contains("påske"))
                        {
                            billedeUrl = Url.Content("~/Images/Påskechokolade.png");
                        }
                        else if (chokoladeNavn.Contains("marcipan"))
                        {
                            billedeUrl = Url.Content("~/Images/marcipanchokolade.png");
                        }
                        else if (chokoladeNavn.Contains("dubai"))
                        {
                            billedeUrl = Url.Content("~/Images/dubaichokolade.png");
                        }
                    }
                    }

                    <div class="image-placeholder" aria-label="Produktbillede">
                        @if (!string.IsNullOrWhiteSpace(billedeUrl))
                        {
                            <img src="@billedeUrl"
                                 alt="@c.Navn"
                                 style="width:100%; height:100%; object-fit:cover; border-radius:10px;" />
                        }
                        else
                        {
                            <span>🍫 Intet billede</span>
                        }
                    </div>

                    <h3>@c.Navn</h3>

                    <p>@c.Beskrivelse</p>

                    <p class="fw-bold product-price">Pris: @c.VisPris()</p>
                </div>

                <div class="product-actions">

                    <a class="product-btn details-btn"
                       asp-page="/Produktside"
                       asp-route-id="@c.Id">
                        Kig nærmere
                    </a>

                    <form method="post"
                          asp-page="/Kataloger/HalloweenKatalog"
                          asp-page-handler="TilføjTilKurv">

                        <input type="hidden"
                               name="chokoladeId"
                               value="@c.Id" />

                        <button type="submit"
                                class="product-btn cart-btn">
                            🛒 Læg i kurv
                        </button>

                    </form>

                </div>

            </div>
        }

    </div>

</div>
