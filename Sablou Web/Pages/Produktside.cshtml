@page
@model Sablou_Web.Pages.ProduktsideModel
@using Sablou_Web.Pages.BrugerLogin
@using System.Globalization
@using Sablou_Web.Models
@{
}


<header>
    <h1>@Model.Chokoladen.Navn</h1>
</header>
<tbody>
<div class="row">
    <div class="col">
        Vis billede her
    </div>
    <div class="col">
            <div class="card" style="width: 20rem; height: 40rem">
                <div class="card-body">
                    Vis/tilføj kurv funktion her

                    <div class="qty-controls" aria-label="Antal for @Model.AntalChokolader">
                        <form method="post" asp-page-handler="ReducerAntal" class="m-0">
                            <input type="hidden" name="chokoladeId" value="@Model.AntalChokolader" />
                            <button type="submit" class="qty-btn" aria-label="Reducer antal">−</button>
                        </form>

                        <span class="qty-value">@Model.AntalChokolader</span>

                        <form method="post" asp-page-handler="OpretAntal" class="m-0">
                            <input type="hidden" name="chokoladeId" value="@Model.AntalChokolader" />
                            <button type="submit" class="qty-btn" aria-label="Øg antal">+</button>
                        </form>
                    </div>
                   @*  <div class="fw-bold">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", linje.Subtotal)</div> *@

                </div>
            </div>
    </div>
</div>

<div class="card" >
    <div class="card-body">
        Her står beskrivelsen af chokoladen
        @Model.Chokoladen.Beskrivelse
    </div>
</div>
    <div class="card">
        <div class="card-body">
            <strong>Produktinformation</strong>

            @{
                var ingrediensIds = Model.Repositories.IngrediensListeRepository.Data.Values
                .Where(il => il.ChokoladeId == Model.Chokoladen.Id)
                .Select(il => il.IngrediensId)
                .ToList();

                var ingredienser = Model.Repositories.IngrediensRepository.Data.Values
                .Where(i => ingrediensIds.Contains(i.Id))
                .ToList();
            }

            @if (ingredienser.Any())
            {
                <ul class="list-group mt-3">
                    @foreach (var ingrediens in ingredienser)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <strong>@ingrediens.Navn</strong>
                                @if (!string.IsNullOrWhiteSpace(ingrediens.Beskrivelse))
                                {
                                    <span class="text-muted">- @ingrediens.Beskrivelse</span>
                                }
                            </span>

                            @if (Sablou_Web.Pages.BrugerLogin.LoginModel.CurrentBruger?.Rolle == "Admin")
                            {
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-page="/Ingredienser/Opdater"
                                   asp-route-id="@ingrediens.Id">
                                    Rediger ingrediens
                                </a>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>Ingen ingredienser fundet.</p>
            }
        </div>
    </div>
</tbody>

