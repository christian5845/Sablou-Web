@page
@model Sablou_Web.Pages.ProduktsideModel
@{
}


<header>
    <h1>@Model.Chokoladen.Navn</h1>
</header>
<tbody>
<div class="row">
    <div class="col">
        Vis billede her
    </div>
    <div class="col">
            <div class="card" style="width: 20rem; height: 40rem">
                <div class="card-body">
                    Vis/tilføj kurv funktion her
                </div>
            </div>
    </div>
</div>

<div class="card" >
    <div class="card-body">
        Her står beskrivelsen af chokoladen
        @Model.Chokoladen.Beskrivelse
    </div>
</div>
    <div class="card">
        <div class="card-body">
            <strong>Produktinformation</strong>

            @{
                var ingrediensIds = Model.Repositories.IngrediensListeRepository.Data.Values
                .Where(il => il.ChokoladeId == Model.Chokoladen.Id)
                .Select(il => il.IngrediensId)
                .ToList();

                var ingredienser = Model.Repositories.IngrediensRepository.Data.Values
                .Where(i => ingrediensIds.Contains(i.Id))
                .Select(i => i.Navn);
            }

            <p>@string.Join(", ", ingredienser)</p>
        </div>
    </div>
</tbody>

