@using Microsoft.AspNetCore.Http
@using Sablou_Web.Pages.BrugerLogin
@inject Sablou_Web.Services.IDataService DataService
@{
    var cartCount = 0;
    if (LoginModel.CurrentBruger != null)
    {
        var kurv = DataService.KurvRepository.Data.Values.FirstOrDefault(k => k.BrugerId == LoginModel.CurrentBruger.Id);
        if (kurv != null)
        {
            cartCount = DataService.KurvLinjeRepository.Data.Values
                .Where(l => l.KurvId == kurv.Id)
                .Sum(l => l.Antal);
        }
    }
    else
    {
        var guestCartJson = Context.Session.GetString("GæsteKurv");
        if (!string.IsNullOrWhiteSpace(guestCartJson))
        {
            var guestCart = System.Text.Json.JsonSerializer.Deserialize<List<Sablou_Web.Models.KurvLinje>>(guestCartJson);
            cartCount = guestCart?.Sum(l => l.Antal) ?? 0;
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sablou_Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sablou_Web.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poiret+One&family=Allison&display=swap" rel="stylesheet">

    <style>
        :root {
            --navbar-height: 72px; /* adjust if your navbar height differs */
        }

        /* When navbar is fixed, add top padding so page content sits below it */
        body {
            padding-top: var(--navbar-height);
        }

        .navbar-brand {
            display: flex !important;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding-right: 0.25rem;
            padding-left: 0.25rem;
        }

            .navbar-brand .brand-title {
                font-size: 2rem;
                line-height: 1;
                font-weight: 700;
                letter-spacing: 0.5px;
                font-family: 'Poiret One';
            }

            .navbar-brand .brand-sub {
                font-size: 1.4rem;
                color: #6c757d;
                margin-top: 2px;
                line-height: 1;
                font-family: 'Allison';
            }

        .cart-link {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding-right: 0.75rem !important;
        }

        .cart-badge {
            position: absolute;
            top: -0.25rem;
            right: -0.15rem;
            min-width: 1.25rem;
            height: 1.25rem;
            padding: 0 0.35rem;
            border-radius: 999px;
            background: #dc3545;
            color: white;
            font-size: 0.75rem;
            font-weight: 700;
            line-height: 1.25rem;
            text-align: center;
            box-shadow: 0 4px 10px rgba(220, 53, 69, 0.35);
            animation: cart-badge-pop 220ms ease-out;
        }

        .dropdown-header {
            font-family: 'Poiret One', cursive;
            font-size: 1rem;
            font-weight: 400; 
            color: black;
            font-weight: bold;
        }

        .nav-link,
        .dropdown-item,
        .dropdown-toggle {
            font-family: 'Poiret One';
            font-size: 1rem;

        @@keyframes cart-badge-pop {
            0% {
                transform: scale(0.6);
                opacity: 0;
            }

            70% {
                transform: scale(1.12);
                opacity: 1;
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar fixed-top navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Forside">
                    <span class="brand-title">Sabloú</span>
                    <small class="brand-sub">Håndlavet chokolade</small>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">                 
                        <li class="nav-item">
                            <a class="nav-link text-dark cart-link" asp-area="" asp-page="/Kurve/Kurv">
                                🛒
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge" aria-label="@cartCount varer i kurven">@cartCount</span>
                                }
                            </a>
                        </li>
                        @{
                            @if (LoginModel.CurrentBruger != null)
                            {

                                // <li class="nav-item nav-link text-dark me-3">
                                //     <span>Navn:</span> <span><b>@LoginModel.CurrentBruger.Navn</b></span>
                                // </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="menu" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                    @LoginModel.CurrentBruger.Navn
                                </a>
                                    <ul class="dropdown-menu" aria-labelledby="menu">
                                        <li><a class="dropdown-item" asp-area="" asp-page="/RedigerProfil/MinSide">Min Side</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/MineBestillinger">Mine Bestillinger</a></li>
                                    </ul>
                                </li>
                            }
                        }
                        @{

                            // Vis kunne dette menu-punkt, hvis en User med "admin"-rolle er logget ind
                            if (LoginModel.CurrentBruger?.Rolle == "Admin" /*Context.User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value == "admin"*/)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="menu" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        Admin
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="menu">
                                        <li><a class="dropdown-item" asp-area="" asp-page="/VoresChokolader">Alle produkter</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/Chokolader/Oversigt">Opret chokolader</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/OpdaterHøjtid" asp-route-id="OpdaterHøjtid">Opdater højtid</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/Brugere/Brugerliste" asp-route-id="Brugerliste">Brugerliste</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/Ingredienser/Alle" asp-route-id="signatur">Vores ingredienser</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-page="/Betalinger/Bestillinger">📋 Bestillinger</a></li>
                                    </ul>
                                </li>
                            }
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="menu" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Menu
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="menu">
                                <li><a class="dropdown-item" asp-area="" asp-page="/VoresChokolader" asp-route-id="VoresChokolader">Vores Chokolader</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/om">Om os</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li <h5 style="" class="dropdown-header">Højtider </h5> </li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/VoresHøjtid" asp-route-id="VoresHøjtid">Om vores højtider</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/PåskeKatalog" asp-route-id="PåskeKatalog">Påske</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/MorsdagKatalog" asp-route-id="MorsDagKatalog">Mors dag</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/FarsDagKatalog" asp-route-id="FarsDagKatalog">Fars dag</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Kataloger/HalloweenKatalog" asp-route-id="HalloweenKatalog">Halloween</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Brugere/BrugerOprettelse">Opret bruger</a></li>
                                @{
                                    if (LoginModel.CurrentBruger == null) // Ingen logget ind -> vis "Log ind"
                                    {
                                        <li><a class="dropdown-item" asp-area="" asp-page="/BrugerLogin/Login">Log ind</a></li>
                                    }
                                    else // En User er logget ind -> vis navn og "Log ud"
                                    {

                                        <li><a class="dropdown-item" asp-area="" asp-page="/BrugerLogin/Logout">Log ud</a></li>
                                    }
                                }

                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Sablou_Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>