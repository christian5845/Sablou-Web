@page
@{
    ViewData["Title"] = "Forside";
}

<style>
    /* Hero fills viewport minus navbar (adjust --navbar-height if needed) */
    :root {
        --navbar-height: 72px;
    }

    body {
        margin: 0;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    }

    .hero-full {
        position: fixed;
        top: var(--navbar-height);
        left: 0;
        right: 0;
        height: calc(100vh - var(--navbar-height));
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        z-index: 900; /* keep below footer */
        overflow: hidden;
    }

    /* shared background layer styles */
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: left center;
        background-repeat: no-repeat;
        transform-origin: left center;
        will-change: transform, opacity;
        backface-visibility: hidden;
        z-index: 0;
        pointer-events: none;
        /* GPU hint */
        transform: translateZ(0) scale(1);
        -webkit-transform: translateZ(0) scale(1);
        /* total cycle 30s = 10s per image */
        animation: hero-fadeZoom 30s ease-in-out infinite;
        -webkit-animation: hero-fadeZoom 30s ease-in-out infinite;
        opacity: 0;
    }

    /* stagger start times for three images (0s, 10s, 20s) */
    .hero-bg.bg1 { animation-delay: 0s; -webkit-animation-delay: 0s; }
    .hero-bg.bg2 { animation-delay: 10s; -webkit-animation-delay: 10s; }
    .hero-bg.bg3 { animation-delay: 20s; -webkit-animation-delay: 20s; }

    /* subtle dark overlay */
    .hero-full::before{
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.35);
        pointer-events: none;
        z-index: 1; /* overlay above background */
    }

    /* Center the text regardless of the .container width */
    .hero-content {
        position: relative;
        z-index: 2; /* content on top of overlay */
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 0 1rem; /* small horizontal padding so text doesn't touch edges on small screens */
        box-sizing: border-box;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        margin: 0;
    }

    .hero-sub {
        font-size: 1.1rem;
        margin-top: 0.5rem;
        opacity: 0.9;
    }

    /* page content sits below fixed hero; do not raise its z-index */
    .page-content {
        position: relative;
        padding: 2rem;
        padding-top: calc(100vh - var(--navbar-height) + 2rem); /* push content below hero */
        background: #fff;
        color: #111;
        min-height: 50vh;
    }

    .site-footer {
        position: relative; /* ensure footer can sit above fixed hero */
        z-index: 1001;     /* higher than .hero-full (900) so footer appears on top */
        background: #0f1720;
        color: #e6eef8;
        padding: 1.25rem 1rem;
        text-align: center;
        font-size: 0.95rem;
        border-top: 1px solid rgba(255,255,255,0.04);
    }

    .site-footer a {
        color: #e6eef8;
        text-decoration: underline;
        opacity: 0.9;
    }

    /* animation: each image now zooms in then zooms out during its own 10s window
       slower, smoother zoom; quick fades to preserve sharp image change */
    @@keyframes hero-fadeZoom {
        0%   { opacity: 0; transform: translateZ(0) scale(1); }
        8%   { opacity: 1; transform: translateZ(0) scale(1); }       /* quick fade in */
        50%  { opacity: 1; transform: translateZ(0) scale(1.12); }    /* zoom-in peak (middle of slide) */
        85%  { opacity: 1; transform: translateZ(0) scale(1.00); }    /* zoom-out */
        95%  { opacity: 0; transform: translateZ(0) scale(1); }       /* quick fade out */
        100% { opacity: 0; transform: translateZ(0) scale(1); }
    }

    @@-webkit-keyframes hero-fadeZoom {
        0%   { opacity: 0; -webkit-transform: translateZ(0) scale(1); transform: translateZ(0) scale(1); }
        8%   { opacity: 1; -webkit-transform: translateZ(0) scale(1); transform: translateZ(0) scale(1); }
        50%  { opacity: 1; -webkit-transform: translateZ(0) scale(1.12); transform: translateZ(0) scale(1.12); }
        85%  { opacity: 1; -webkit-transform: translateZ(0) scale(1.00); transform: translateZ(0) scale(1.00); }
        95%  { opacity: 0; -webkit-transform: translateZ(0) scale(1); transform: translateZ(0) scale(1); }
        100% { opacity: 0; -webkit-transform: translateZ(0) scale(1); transform: translateZ(0) scale(1); }
    }
</style>

<section class="hero-full" role="img" aria-label="Håndlavet chokolade">
    <div class="hero-bg bg1" style="background-image:url('@Url.Content("~/images/choko1.PNG")');"></div>
    <div class="hero-bg bg2" style="background-image:url('@Url.Content("~/images/choko2.PNG")');"></div>
    <div class="hero-bg bg3" style="background-image:url('@Url.Content("~/images/choko3.PNG")');"></div>

    <div class="hero-content container">
        <h1 class="hero-title">Håndlavet chokolade</h1>
        <p class="hero-sub">Lavet med kærlighed</p>
    </div>
</section>

<main class="page-content container">

    <!-- Footer placed after the main content -->
    <footer class="site-footer" role="contentinfo">
        <div>© @DateTime.Now.Year Sablou — All rights reserved.</div>
        <div style="margin-top:0.5rem; font-size:0.9rem;">
            <a href="/kontakt">Kontakt</a> · <a href="/om">Om os</a>
        </div>
    </footer>
</main>
