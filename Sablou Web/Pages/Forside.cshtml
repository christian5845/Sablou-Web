@page
@{
    ViewData["Title"] = "Forside";
}

<style>
    /* Hero fills viewport minus navbar (adjust --navbar-height if needed) */
    :root {
        --navbar-height: 72px;
    }

    body {
        margin: 0;
    }

    .hero-full {
        position: fixed;
        top: var(--navbar-height);
        left: 0;
        right: 0;
        height: calc(100vh - var(--navbar-height));
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        z-index: 0;
        overflow: hidden;
    }

    /* shared background layer styles */
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: left center;
        background-repeat: no-repeat;
        transform-origin: left center;
        will-change: transform, opacity;
        backface-visibility: hidden;
        z-index: 0;
        pointer-events: none;
        /* GPU hint */
        transform: translateZ(0) scale(1);
        -webkit-transform: translateZ(0) scale(1);
        animation: hero-fadeZoom 24s ease-in-out infinite;
        -webkit-animation: hero-fadeZoom 24s ease-in-out infinite;
        opacity: 0;
    }

    /* stagger start times for three images (0s, 8s, 16s) */
    .hero-bg.bg1 { animation-delay: 0s; -webkit-animation-delay: 0s; }
    .hero-bg.bg2 { animation-delay: 8s; -webkit-animation-delay: 8s; }
    .hero-bg.bg3 { animation-delay: 16s; -webkit-animation-delay: 16s; }

    /* subtle dark overlay */
    .hero-full::before{
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.35);
        pointer-events: none;
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        margin: 0;
    }

    .hero-sub {
        font-size: 1.1rem;
        margin-top: 0.5rem;
        opacity: 0.9;
    }

    /* animation: quick fade-in, slow zoom while visible, fade-out */
    @@keyframes hero-fadeZoom {
        0%   { opacity: 0; transform: translateZ(0) scale(1); }
        4%   { opacity: 1; transform: translateZ(0) scale(1.03); }
        30%  { opacity: 1; transform: translateZ(0) scale(1.09); }
        34%  { opacity: 0; transform: translateZ(0) scale(1.12); }
        100% { opacity: 0; transform: translateZ(0) scale(1.12); }
    }

    /* WebKit fallback */
    @@-webkit-keyframes hero-fadeZoom {
        0%   { opacity: 0; -webkit-transform: translateZ(0) scale(1); transform: translateZ(0) scale(1); }
        4%   { opacity: 1; -webkit-transform: translateZ(0) scale(1.03); transform: translateZ(0) scale(1.03); }
        30%  { opacity: 1; -webkit-transform: translateZ(0) scale(1.09); transform: translateZ(0) scale(1.09); }
        34%  { opacity: 0; -webkit-transform: translateZ(0) scale(1.12); transform: translateZ(0) scale(1.12); }
        100% { opacity: 0; -webkit-transform: translateZ(0) scale(1.12); transform: translateZ(0) scale(1.12); }
    }
</style>

<section class="hero-full" role="img" aria-label="Håndlavet chokolade">
    <div class="hero-bg bg1" style="background-image:url('@Url.Content("~/images/choko.PNG")');"></div>
    <div class="hero-bg bg2" style="background-image:url('@Url.Content("~/images/choko2.PNG")');"></div>
    <div class="hero-bg bg3" style="background-image:url('@Url.Content("~/images/choko3.PNG")');"></div>

    <div class="hero-content container">
        <h1 class="hero-title">Sablou</h1>
        <p class="hero-sub">Håndlavet chokolade</p>
    </div>
</section>
