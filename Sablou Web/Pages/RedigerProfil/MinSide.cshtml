@page
@model Sablou_Web.Pages.RedigerProfil.MinSideModel

@{
    var navn = Model.Bruger?.Navn?.Trim();
    var initial = string.IsNullOrWhiteSpace(navn) ? "?" : navn[..1].ToUpperInvariant();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="mb-4">
                <h1 class="display-6 fw-semibold mb-2">Min side</h1>
                <p class="text-muted mb-0">Her kan du se og opdatere dine oplysninger.</p>
            </div>

            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-primary-subtle border-0 py-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-semibold flex-shrink-0"
                             style="width: 64px; height: 64px;">
                            @initial
                        </div>

                        <div class="flex-grow-1">
                            <h2 class="h4 mb-1">@Model.Bruger.Navn</h2>
                            <div class="text-muted">@Model.Bruger.Email</div>
                        </div>

                        <span class="badge rounded-pill @(Model.Bruger.Rolle == "Admin" ? "text-bg-danger" : "text-bg-secondary")">
                            @Model.Bruger.Rolle
                        </span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 bg-body-tertiary rounded-3 h-100">
                                <div class="text-muted small text-uppercase mb-1">Navn</div>
                                <div class="fw-semibold">@Model.Bruger.Navn</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-body-tertiary rounded-3 h-100">
                                <div class="text-muted small text-uppercase mb-1">Email</div>
                                <div class="fw-semibold">@Model.Bruger.Email</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-body-tertiary rounded-3 h-100">
                                <div class="text-muted small text-uppercase mb-1">Adresse</div>
                                <div class="fw-semibold">@Model.Bruger.Adresse</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-body-tertiary rounded-3 h-100">
                                <div class="text-muted small text-uppercase mb-1">Telefon</div>
                                <div class="fw-semibold">
                                    @(Model.Bruger.Telefonnummer?.ToString() ?? "Ikke angivet")
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <a asp-area="" asp-page="/RedigerProfil/RedigerProfil" class="btn btn-primary px-4">
                            Rediger profil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>