@page
@model Sablou_Web.Pages.Chokolader.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Chokolade</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Chokolade.Id" class="control-label"></label>
                <input asp-for="Chokolade.Id" class="form-control" />
                <span asp-validation-for="Chokolade.Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Chokolade.Navn" class="control-label"></label>
                <input asp-for="Chokolade.Navn" class="form-control" />
                <span asp-validation-for="Chokolade.Navn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Chokolade.Stykpris" class="control-label"></label>
                <input asp-for="Chokolade.Stykpris" class="form-control" />
                <span asp-validation-for="Chokolade.Stykpris" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Chokolade.Beskrivelse" class="control-label"></label>
                <input asp-for="Chokolade.Beskrivelse" class="form-control" />
                <span asp-validation-for="Chokolade.Beskrivelse" class="text-danger"></span>
                <div class="form-group">
                    <label>Ingredienser</label>

                    @foreach (var ingrediens in Model.IngrediensValg)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="ValgteIngrediensIds"
                                   value="@ingrediens.Value" />

                            <label class="form-check-label">
                                @ingrediens.Text
                            </label>
                        </div>
                    }
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
