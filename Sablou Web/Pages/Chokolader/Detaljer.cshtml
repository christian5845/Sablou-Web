@page
@model Sablou_Web.Pages.Chokolader.DetaljerModel
@using Sablou_Web.Models
@{
    ViewData["Title"] = "Detaljer";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Detaljer</h2>
            <p class="text-muted mb-0">Se oplysningerne for den valgte chokolade.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="/Chokolader/Opdater" asp-route-id="@Model.Chokolade.Id" class="btn btn-outline-secondary">Opdater</a>
            <a asp-page="/Chokolader/Oversigt" class="btn btn-outline-primary">Tilbage</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h4 class="card-title mb-3">Chokolade</h4>
            <dl class="row mb-0">
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Navn)
                </dt>
                <dd class="col-sm-9 col-lg-10">
                    @Html.DisplayFor(model => model.Chokolade.Navn)
                </dd>
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Stykpris)
                </dt>
                <dd class="col-sm-9 col-lg-10">
                    @Model.Chokolade.VisPris()
                </dd>
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Beskrivelse)
                </dt>
                <dd class="col-sm-9 col-lg-10 mb-0">
                    @Html.DisplayFor(model => model.Chokolade.Beskrivelse)
                </dd>
            </dl>
        </div>
    </div>
</div>
