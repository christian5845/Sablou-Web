@page
@model Sablou_Web.Pages.Chokolader.OpretModel

@{
    ViewData["Title"] = "Opret";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Opret</h2>
            <p class="text-muted mb-0">Opret en ny chokolade i systemet.</p>
        </div>
        <a asp-page="Oversigt" class="btn btn-outline-primary">Tilbage</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h4 class="card-title mb-3">Chokolade</h4>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="Chokolade.Navn" class="form-label"></label>
                    <input asp-for="Chokolade.Navn" class="form-control" />
                    <span asp-validation-for="Chokolade.Navn" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Chokolade.Stykpris" class="form-label"></label>
                    <input asp-for="Chokolade.Stykpris" class="form-control" />
                    <span asp-validation-for="Chokolade.Stykpris" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Chokolade.Beskrivelse" class="form-label"></label>
                    <input asp-for="Chokolade.Beskrivelse" class="form-control" />
                    <span asp-validation-for="Chokolade.Beskrivelse" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label">Ingredienser</label>

                    @foreach (var ingrediens in Model.IngrediensValg)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="ValgteIngrediensIds"
                                   value="@ingrediens.Value" />

                            <label class="form-check-label">
                                @ingrediens.Text
                            </label>
                        </div>
                    }
                </div>
                <div class="d-flex gap-2">
                    <input type="submit" value="Opret" class="btn btn-primary" />
                    <a asp-page="Oversigt" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
