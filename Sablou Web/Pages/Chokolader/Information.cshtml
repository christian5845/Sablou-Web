@page "{id:int}"
@model Sablou_Web.Pages.Chokolader.InformationModel

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">@Model.Chokolade?.Navn</h2>
            <p class="text-muted mb-0">Detaljer og beskrivelse af chokoladen.</p>
        </div>
        <a asp-page="/VoresChokolader" class="btn btn-outline-primary">Tilbage</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="row g-0">
            <div class="col-md-4 d-flex align-items-center justify-content-center p-4 bg-light">
                <img src="~/images/chokolade.jpg" class="img-fluid rounded" style="max-width: 300px;" alt="@Model.Chokolade?.Navn" />
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h4 class="card-title">Information</h4>
                    <p class="mb-2"><strong>Pris:</strong> @($"{Model.Chokolade?.Stykpris:0.00} kroner")</p>
                    <p class="mb-0"><strong>Beskrivelse:</strong> @Model.Chokolade?.Beskrivelse</p>
                </div>
            </div>
        </div>
    </div>
</div>
