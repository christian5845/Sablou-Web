@page
@model Sablou_Web.Pages.Chokolader.SletModel

@{
    ViewData["Title"] = "Slet";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Slet</h2>
            <p class="text-muted mb-0">Bekræft at du vil fjerne chokoladen.</p>
        </div>
        <a asp-page="/Chokolader/Oversigt" class="btn btn-outline-primary">Tilbage</a>
    </div>

    <div class="card shadow-sm border-0 border-danger">
        <div class="card-body">
            <h4 class="card-title text-danger mb-3">Er du sikker på du vil slette dette?</h4>
            <dl class="row mb-4">
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Navn)
                </dt>
                <dd class="col-sm-9 col-lg-10">
                    @Html.DisplayFor(model => model.Chokolade.Navn)
                </dd>
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Stykpris)
                </dt>
                <dd class="col-sm-9 col-lg-10">
                    @Html.DisplayFor(model => model.Chokolade.Stykpris)
                </dd>
                <dt class="col-sm-3 col-lg-2">
                    @Html.DisplayNameFor(model => model.Chokolade.Beskrivelse)
                </dt>
                <dd class="col-sm-9 col-lg-10 mb-0">
                    @Html.DisplayFor(model => model.Chokolade.Beskrivelse)
                </dd>
            </dl>

            <form method="post" class="d-flex gap-2">
                <input type="hidden" asp-for="Chokolade.Id" />
                <input type="submit" value="Slet" class="btn btn-danger" />
                <a asp-page="/Chokolader/Oversigt" class="btn btn-outline-secondary">Annuller</a>
            </form>
        </div>
    </div>
</div>
