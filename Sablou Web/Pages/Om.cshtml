@page
@model Sablou_Web.Pages.OmModel
@{
    ViewData["Title"] = "Om Sabloú";
}

<section class="hero">
    <div class="overlay">
        <div class="hero-content">
            <h1>Om Sabloú</h1>
            <p>
                Håndlavet kvalitetschokolade med fokus på design, kreativitet og smag.
            </p>
        </div>
    </div>
</section>

<section class="about-section container">
    <div class="text-content">
        <h2>Historien bag Sabloú</h2>
        <p>
            Sabloú blev grundlagt i 2003 af de to veninder Sabrina og Louise,
            som deler en passion for eksklusiv chokolade og kreativt design.
            Sammen skaber de håndlavet kvalitetschokolade, hvor både smag og
            æstetik er i centrum.
        </p>

        <p>
            Hos Sabloú handler chokolade ikke kun om smag – det handler om oplevelser.
            Derfor arbejder virksomheden med unikke former, farver og detaljer,
            der gør hvert stykke chokolade til noget helt særligt.
        </p>

        <p>
            Sabrina og Louise elsker at skabe kreative kollektioner til årets højtider,
            hvor inspiration fra jul, påske, valentinsdag og andre særlige begivenheder
            bliver omsat til smukke designs og elegante smagsoplevelser.
        </p>
    </div>

    <div class="image-grid">
        <img src="~/images/choko4.PNG" alt="Sabloú håndlavet chokolade" />
        <img src="~/images/choko5.PNG" alt="Design chokolade fra Sabloú" />
        <img src="~/images/choko6.PNG" alt="Kreativ luksuschokolade" />
    </div>
</section>

<section class="values-section">
    <div class="container values-grid">
        <div class="value-card">
            <h3>Håndlavet kvalitet</h3>
            <p>
                Hver enkelt chokolade bliver skabt med omhu og passion for detaljer.
            </p>
        </div>

        <div class="value-card">
            <h3>Kreativt design</h3>
            <p>
                Farver, former og elegante udtryk gør Sabloús chokolade unik.
            </p>
        </div>

        <div class="value-card">
            <h3>Smag i fokus</h3>
            <p>
                Kombinationen af udsøgte råvarer og kreative smage skaber en eksklusiv oplevelse.
            </p>
        </div>
    </div>
</section>
<style>font-family: "POIRET ONE"</style>
<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background-color: #ffffff; /* Updated to align with shared site background color */
        color: #3a2a22;
    }

    .container {
        width: 90%;
        max-width: 1200px;
        margin: auto;
    }

    .hero {
        height: 70vh;
        background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
                    url('/images/choko4.PNG') center/cover no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
    }

    .hero-content h1 {
        font-size: 4rem;
        margin-bottom: 1rem;
        letter-spacing: 2px;
    }

    .hero-content p {
        font-size: 1.3rem;
        max-width: 700px;
        margin: auto;
    }

    .about-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        padding: 5rem 0;
        align-items: center;
    }

    .text-content h2 {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
        color: #5b3424;
    }

    .text-content p {
        line-height: 1.8;
        margin-bottom: 1.5rem;
        font-size: 1.05rem;
    }

    .image-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .image-grid img {
        width: 100%;
        border-radius: 20px;
        object-fit: cover;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        transition: transform 0.3s ease;
    }

    .image-grid img:hover {
        transform: scale(1.03);
    }

    .values-section {
        background-color: #f1e7dc;
        padding: 5rem 0;
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .value-card {
        background: white;
        padding: 2rem;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        text-align: center;
    }

    .value-card h3 {
        margin-bottom: 1rem;
        color: #7a4731;
    }

    .value-card p {
        line-height: 1.6;
    }

    @@media (max-width: 900px) {
        .about-section,
        .values-grid {
            grid-template-columns: 1fr;
        }

        .hero-content h1 {
            font-size: 2.8rem;
        }

        .image-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
