@page
@model Sablou_Web.Pages.Kurve.BetalingModel
@using Sablou_Web.Pages.BrugerLogin
@using System.Globalization
@using Sablou_Web.Models
@{
    ViewData["Title"] = "Betaling";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Kurve/Kurv">Kurv</a></li>
            <li class="breadcrumb-item active" aria-current="page">Betaling</li>
        </ol>
    </nav>

    <h2 class="mb-4">Gennemfør din bestilling</h2>

    @if (Model.KurvLinjer == null || !Model.KurvLinjer.Any())
    {
        <div class="alert alert-info">
            Din kurv er tom. <a asp-page="/Chokolader/VoresChokolader">Se vores chokolader</a>
        </div>
    }
    else
    {
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong>✓ Bestilling modtaget!</strong> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Luk"></button>
            </div>
        }

        <div class="row g-4">
            <!-- Leveringsoplysninger -->
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-4">Leveringsoplysninger</h5>

                        @if (LoginModel.CurrentBruger != null)
                        {
                            <!-- Logget ind: vis brugeroplysninger auto-udfyldt -->
                            <div class="alert alert-light border mb-4 d-flex align-items-start gap-3">
                                <span style="font-size:1.5rem">👤</span>
                                <div>
                                    <strong>Du er logget ind som @LoginModel.CurrentBruger.Navn</strong><br />
                                    <small class="text-muted">Dine oplysninger er udfyldt automatisk. Du kan rette dem nedenfor.</small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light border mb-4 d-flex align-items-start gap-3">
                                <span style="font-size:1.5rem">🔓</span>
                                <div>
                                    <strong>Du handler som gæst</strong><br />
                                    <small class="text-muted">
                                        Har du en konto? <a asp-page="/BrugerLogin/Login">Log ind</a> for at handle hurtigere.
                                    </small>
                                </div>
                            </div>
                        }

                        <form method="post" asp-page-handler="AfgivBestilling">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Fulde navn <span class="text-danger">*</span></label>
                                    <input asp-for="GæsteNavn" class="form-control"
                                           placeholder="Fx. Anders Andersen"
                                           value="@(LoginModel.CurrentBruger != null ? LoginModel.CurrentBruger.Navn : "")" />
                                    <span asp-validation-for="GæsteNavn" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">E-mail <span class="text-danger">*</span></label>
                                    <input asp-for="GæsteEmail" type="email" class="form-control"
                                           placeholder="din@email.dk"
                                           value="@(LoginModel.CurrentBruger != null ? LoginModel.CurrentBruger.Email : "")" />
                                    <span asp-validation-for="GæsteEmail" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Telefonnummer</label>
                                    <input asp-for="GæsteTelefon" type="tel" class="form-control"
                                           placeholder="12 34 56 78"
                                           value="@(LoginModel.CurrentBruger?.Telefonnummer?.ToString() ?? "")" />
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold">Leveringsadresse <span class="text-danger">*</span></label>
                                    <input asp-for="GæsteAdresse" class="form-control"
                                           placeholder="Fx. Kongens Nytorv 1, 1050 København K"
                                           value="@(LoginModel.CurrentBruger != null ? LoginModel.CurrentBruger.Adresse : "")" />
                                    <span asp-validation-for="GæsteAdresse" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold">Besked til os <small class="text-muted">(valgfri)</small></label>
                                    <textarea asp-for="Besked" class="form-control" rows="3"
                                              placeholder="Evt. særlige ønsker eller leveringsinstruktioner..."></textarea>
                                </div>
                            </div>

                            <hr class="my-4" />

                            <h5 class="mb-3">Betalingsmetode</h5>
                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <label class="payment-option">
                                        <input type="radio" name="BetalingsMetode" value="Kort" checked class="d-none" />
                                        <div class="payment-card selected" id="opt-kort">
                                            <div class="payment-icon">💳</div>
                                            <div>Betalingskort</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-6">
                                    <label class="payment-option">
                                        <input type="radio" name="BetalingsMetode" value="MobilePay" class="d-none" />
                                        <div class="payment-card" id="opt-mobilepay">
                                            <div class="payment-icon">📱</div>
                                            <div>MobilePay</div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-dark btn-lg w-100 py-3">
                                Afgiv bestilling &rarr;
                            </button>
                            <p class="text-muted text-center small mt-2">
                                🔒 Din betaling er sikker og krypteret
                            </p>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Ordreoversigt -->
            <div class="col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Din bestilling</h5>

                        @foreach (var linje in Model.KurvLinjer)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                <div>
                                    <span class="fw-semibold">@linje.Navn</span>
                                    <br />
                                    <small class="text-muted">@linje.Antal stk. × @string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00}", linje.Stykpris) kr.</small>
                                </div>
                                <span class="fw-semibold">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", linje.Subtotal)</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between py-2">
                            <span class="text-muted">Subtotal</span>
                            <span>@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", Model.Total)</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span class="text-muted">Fragt</span>
                            <span>39,00 kr.</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span>@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", Model.Total + 39)</span>
                        </div>
                        <small class="text-muted d-block mt-1">Inkl. moms</small>
                    </div>
                </div>

                <a asp-page="/Kurve/Kurv" class="btn btn-outline-secondary w-100 mt-3">
                    ← Tilbage til kurv
                </a>
            </div>
        </div>
    }
</div>

<style>
    .payment-option { cursor: pointer; display: block; }
    .payment-card {
        border: 2px solid #dee2e6;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        transition: border-color 0.15s, background 0.15s;
        font-weight: 600;
    }
    .payment-card:hover { border-color: #adb5bd; }
    .payment-card.selected { border-color: #212529; background: #f8f9fa; }
    .payment-icon { font-size: 1.75rem; margin-bottom: 0.25rem; }
</style>

<!-- Script til at håndtere valg af betalingsmetode -->
<script>
    document.querySelectorAll('.payment-option input[type=radio]').forEach(radio => {
        radio.addEventListener('change', () => {
            document.querySelectorAll('.payment-card').forEach(c => c.classList.remove('selected'));
            radio.closest('.payment-option').querySelector('.payment-card').classList.add('selected');
        });
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
