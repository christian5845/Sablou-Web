@page
@model Sablou_Web.Pages.Bestillinger.BestillingerModel
@using Sablou_Web.Pages.BrugerLogin
@using System.Globalization
@using Sablou_Web.Models
@{
    ViewData["Title"] = "Bestillinger";
}

@if (LoginModel.CurrentBruger?.Rolle != "Admin")
{
    <div class="container py-5 text-center">
        <div style="font-size:3rem">🔒</div>
        <h3 class="mt-3">Adgang nægtet</h3>
        <p class="text-muted">Denne side er kun tilgængelig for administratorer.</p>
        <a asp-page="/Forside" class="btn btn-dark mt-2">Tilbage til forsiden</a>
    </div>
    return;
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold">📋 Bestillinger</h2>
            <small class="text-muted">Oversigt over alle indgående ordrer</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-dark fs-6">@Model.Ordrer.Count ordre(r)</span>
        </div>
    </div>

    @if (!Model.Ordrer.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem">📭</div>
            <h5 class="mt-3">Ingen bestillinger endnu</h5>
            <p>Nye bestillinger vises her, så snart kunderne afgiver ordrer.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ordre in Model.Ordrer.OrderByDescending(o => o.Dato))
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-3">
                                <div>
                                    <strong class="fs-6">@ordre.Navn</strong>
                                    @if (ordre.ErLoggetInd)
                                    {
                                        <span class="badge bg-success ms-2 fw-normal">Logget ind</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-2 fw-normal">Gæst</span>
                                    }
                                    <br />
                                    <small class="text-muted">
                                        <a href="mailto:@ordre.Email" class="text-muted">@ordre.Email</a>
                                        @if (!string.IsNullOrEmpty(ordre.Telefon))
                                        {
                                            <span> · @ordre.Telefon</span>
                                        }
                                    </small>
                                </div>
                            </div>

                            <div class="text-end d-flex gap-2 align-items-center">
                                <div class="me-2 text-end">
                                    <div class="fw-bold fs-5">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", ordre.Total + 39)</div>
                                    <small class="text-muted">@ordre.Dato.ToString("d. MMMM yyyy 'kl.' HH:mm", new System.Globalization.CultureInfo("da-DK"))</small>
                                </div>

                                <div class="d-flex gap-2">
                                    <form method="post" asp-page-handler="MarkBehandlet" asp-route-id="@int.Parse(ordre.Id)" onsubmit="return confirm('Markér ordre som behandlet?');">
                                        <button type="submit" class="btn btn-sm btn-outline-success">Markér behandlet</button>
                                    </form>

                                    <form method="post" asp-page-handler="Slet" asp-route-id="@int.Parse(ordre.Id)" onsubmit="return confirm('Er du sikker på du vil slette ordren?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Slet</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="card-body py-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Varer</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tbody>
                                            @foreach (var gemtOrdre in ordre.Linjer)
                                            {
                                                <tr>
                                                    <td>@gemtOrdre.Navn</td>
                                                    <td class="text-muted text-center">×@gemtOrdre.Antal</td>
                                                    <td class="text-end">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr." )</td>
                                                </tr>
                                            }
                                            <tr class="border-top">
                                                <td class="text-muted">Fragt</td>
                                                <td></td>
                                                <td class="text-end text-muted">39,00 kr.</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold">Total</td>
                                                <td></td>
                                                <td class="text-end fw-bold">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", ordre.Total + 39)</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="col-md-3">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Levering</h6>
                                    <address class="mb-0 small">
                                        <strong>@ordre.Navn</strong><br />
                                        @ordre.Adresse
                                    </address>
                                </div>

                                <div class="col-md-3">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Bemærkninger</h6>
                                    @if (!string.IsNullOrWhiteSpace(ordre.Besked))
                                    {
                                        <p class="small mb-0 fst-italic">"@ordre.Besked"</p>
                                    }
                                    else
                                    {
                                        <p class="small text-muted mb-0">Ingen bemærkninger</p>
                                    }
                                    <div class="mt-2">
                                        <small class="text-muted">Ordre-ID: <code class="small">@ordre.Id[..Math.Min(ordre.Id.Length,8)]...</code></small>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>
