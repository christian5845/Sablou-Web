@page
@model Sablou_Web.Pages.Brugere.BrugerOprettelseModel
@{
}
<h1 class="display-5 mb-3">Opret ny Bruger</h1>

<form method="post">
    <div class="form-group mb-3">
        <div class="form-group mb-3">
            <label asp-for="@Model.Navn" class="control-lable"></label>
            <input asp-for="@Model.Navn" class="form-control" />
        </div>
    <div>
        <label asp-for="@Model.Email" class="control-lable"></label>
        <input asp-for="@Model.Email" class="form-control" type="email" />
        <span asp-validation-for="@Model.Email" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
            <label asp-for="@Model.Telefonnummer" class="control-lable"></label>
            <input asp-for="@Model.Telefonnummer" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="@Model.Adresse" class="control-lable"></label>
        <input asp-for="@Model.Adresse" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="@Model.Password" class="control-lable"></label>
        <input asp-for="@Model.Password" class="form-control" type="password" />
    </div>
        <div class="form-group mb-3">
            <input type="submit" value="Create" class="btn btn-outline-primary" />
        </div>
    </div>
 </form>
