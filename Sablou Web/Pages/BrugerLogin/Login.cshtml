@page
@model Sablou_Web.Pages.BrugerLogin.LoginModel
@{
}

<style>
    .login-wrapper {
        max-width: 420px;
        margin: 40px auto;
        padding: 30px;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 18px rgba(0,0,0,0.08);
    }

    .login-title {
        font-weight: 600;
        text-align: center;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 8px;
        padding: 10px 14px;
    }

    .btn-modern {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        font-weight: 500;
    }

    .error-message {
        color: #d9534f;
        font-weight: 500;
        margin-bottom: 15px;
        text-align: center;
    }
</style>

<div class="login-wrapper">
    <h1 class="display-6 login-title">Log på</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-message">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" type="email" />
        </div>

        <div class="mb-3">
            <label asp-for="Adgangskode" class="form-label"></label>
            <input asp-for="Adgangskode" class="form-control" type="Adgangskode" />
        </div>

        <div class="mb-3">
            <input type="submit" value="Log ind" class="btn btn-outline-primary btn-modern" />
        </div>
    </form>
</div>
