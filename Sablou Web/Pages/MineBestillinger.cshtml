@page
@model Sablou_Web.Pages.MineBestillingerModel
@using Sablou_Web.Pages.BrugerLogin
@using System.Globalization
@using Sablou_Web.Models
@{
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold">📋 Bestillinger</h2>
            <small class="text-muted">Oversigt over alle dine ordre</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-dark fs-6">@Model.Ordrer.Count ordre(r)</span>
        </div>
    </div>

    @if (!Model.Ordrer.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem">📭</div>
            <h5 class="mt-3">Ingen bestillinger endnu</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ordre in Model.Ordrer.OrderByDescending(o => o.Dato))
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0 @(ordre.ErAnnulleret ? "opacity-75" : "")">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-3">
                            </div>

                            <div class="text-end d-flex gap-2 align-items-center">
                                <div class="me-2 text-end">
                                    <div class="fw-bold fs-5">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", ordre.Total + 39)</div>
                                    <small class="text-muted">@ordre.Dato.ToString("d. MMMM yyyy 'kl.' HH:mm", new System.Globalization.CultureInfo("da-DK"))</small>
                                </div>

                                @* ── 20.1: Slet-knap – vises kun hvis ordren ikke allerede er annulleret ── *@
                                @if (!ordre.ErAnnulleret && !ordre.ErBehandlet)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#bekraeftModal"
                                            data-ordre-id="@ordre.Id">
                                        🗑 Annullér
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="card-body py-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Varer</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tbody>
                                            @foreach (GemtOrdreLinje gol in ordre.Linjer)
                                            {
                                                <tr>
                                                    <td>@gol.Navn</td>
                                                    <td class="text-muted text-center">×@gol.Antal</td>
                                                    <td class="text-end">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", gol.Stykpris * gol.Antal)</td>
                                                </tr>
                                            }
                                            <tr class="border-top">
                                                <td class="text-muted">Fragt</td>
                                                <td></td>
                                                <td class="text-end text-muted">39,00 kr.</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold">Total</td>
                                                <td></td>
                                                <td class="text-end fw-bold">@string.Format(CultureInfo.GetCultureInfo("da-DK"), "{0:0.00} kr.", ordre.Total + 39)</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="col-md-3">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Levering</h6>
                                    <address class="mb-0 small">
                                        <strong>@ordre.Navn</strong><br />
                                        @ordre.Adresse
                                    </address>
                                </div>

                                <div class="col-md-3">
                                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Bemærkninger</h6>
                                    @if (!string.IsNullOrWhiteSpace(ordre.Besked))
                                    {
                                        <p class="small mb-0 fst-italic">"@ordre.Besked"</p>
                                    }
                                    else
                                    {
                                        <p class="small text-muted mb-0">Ingen bemærkninger</p>
                                    }
                                    <div class="mt-2">
                                        <small class="text-muted">Ordre-ID: <code class="small">@ordre.Id[..Math.Min(ordre.Id.Length, 8)]...</code></small>
                                    </div>
                                    <div class="mt-2">
                                        @* ── Status-badge: annulleret / behandlet / under behandling ── *@
                                        @if (ordre.ErAnnulleret)
                                        {
                                            <span class="badge bg-secondary">Annulleret</span>
                                        }
                                        else
                                        {
                                            <span class="badge @(ordre.ErBehandlet ? "bg-success" : "bg-danger")">
                                                @(ordre.ErBehandlet ? "Er Behandlet" : "Under Behandling")
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── 20.2: Bekræftelses-modal med "Ja" og "Nej" ── *@
<div class="modal fade" id="bekraeftModal" tabindex="-1" aria-labelledby="bekraeftModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bekraeftModalLabel">Annullér ordre</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Luk"></button>
            </div>
            <div class="modal-body">
                Er du sikker på, at du vil annullere denne ordre? Dette kan ikke fortrydes.
            </div>
            <div class="modal-footer">
                @* "Nej" lukker modalen uden at gøre noget *@
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Nej</button>

                @* "Ja" submitter den skjulte formular *@
                <form method="post" asp-page-handler="Annuller" id="annullerForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="annullerOrdreId" value="" />
                    <button type="submit" class="btn btn-danger">Ja, annullér</button>
                </form>
            </div>
        </div>
    </div>
</div>

@* ── JavaScript: sæt ordre-ID i formularen når modalen åbnes ── *@
<script>
    document.getElementById('bekraeftModal').addEventListener('show.bs.modal', function (event) {
        // Knappen der triggede modalen
        var knap = event.relatedTarget;
        // Hent ordre-ID fra data-attributten
        var ordreId = knap.getAttribute('data-ordre-id');
        // Sæt ID i det skjulte felt
        document.getElementById('annullerOrdreId').value = ordreId;
    });
</script>
