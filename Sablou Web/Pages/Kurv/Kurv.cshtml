@page
@model Sablou_Web.Pages.Kurv.KurvModel
@using Sablou_Web.Pages.BrugerLogin
@{
    ViewData["Title"] = "Din kurv";
}

<div class="container py-5">
    <h2 class="mb-4">🛒 @(LoginModel.CurrentBruger != null ? $"{LoginModel.CurrentBruger.Navn}s kurv" : "Gæstekurv")</h2>

    <div class="row">
        <!-- Kurv-varer -->
        <div class="col-md-8">
            <div class="card shadow-sm mb-3">
                <div class="card-body d-flex align-items-center gap-3">
                    <img src="~/images/chokolade-placeholder.jpg"
                         alt="Produkt" width="80" height="80"
                         class="rounded" style="object-fit:cover;" />
                    <div class="flex-grow-1">
                        <h5 class="mb-1">Signaturmørk 75%</h5>
                        <small class="text-muted">Håndlavet mørk chokolade</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-sm">−</button>
                        <span>1</span>
                        <button class="btn btn-outline-secondary btn-sm">+</button>
                    </div>
                    <div class="fw-bold">49,00 kr</div>
                    <button class="btn btn-link text-danger p-0">✕</button>
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-body d-flex align-items-center gap-3">
                    <img src="~/images/chokolade-placeholder.jpg"
                         alt="Produkt" width="80" height="80"
                         class="rounded" style="object-fit:cover;" />
                    <div class="flex-grow-1">
                        <h5 class="mb-1">Saltkaramel</h5>
                        <small class="text-muted">Blød karamel med havsalt</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-sm">−</button>
                        <span>2</span>
                        <button class="btn btn-outline-secondary btn-sm">+</button>
                    </div>
                    <div class="fw-bold">98,00 kr</div>
                    <button class="btn btn-link text-danger p-0">✕</button>
                </div>
            </div>
        </div>

        <!-- Ordreoversigt -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Ordreoversigt</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span>147,00 kr</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Fragt</span>
                        <span>39,00 kr</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span>186,00 kr</span>
                    </div>
                    <a href="#" class="btn btn-dark w-100">Gå til betaling</a>
                </div>
            </div>
        </div>
    </div>
</div>