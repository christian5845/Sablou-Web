@page
@model Sablou_Web.Pages.Ingredienser.OpdaterModel

@{
    ViewData["Title"] = "Rediger ingrediens";
}

<h1 class="display-5 mb-4">Rediger ingrediens</h1>

<form method="post" class="card shadow-sm p-4">

    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="form-group mb-3">
        <label asp-for="Navn" class="form-label"></label>
        <input asp-for="Navn" class="form-control" />
        <span asp-validation-for="Navn" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Beskrivelse" class="form-label"></label>
        <textarea asp-for="Beskrivelse" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Beskrivelse" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            Gem ændringer
        </button>

        <a asp-page="/Ingredienser/Alle" class="btn btn-secondary">
            Tilbage
        </a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}