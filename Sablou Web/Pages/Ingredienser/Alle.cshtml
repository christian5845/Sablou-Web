@page
@model Sablou_Web.Pages.Ingredienser.AlleModel
@{
}

<div class="container py-4">
    <div class="text-center mb-4">
        <h1 class="fw-bold">Ingredienser</h1>
        <p class="text-muted mb-0">Administrer dine ingredienser herfra.</p>
    </div>

    <div class="d-flex justify-content-end mb-4">
        <a class="btn btn-primary" asp-page="Opret">+ Opret ny ingrediens</a>
    </div>

    @if (Model.Repositories.IngrediensRepository != null && Model.Repositories.IngrediensRepository.Data.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model.Repositories.IngrediensRepository.Data)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@item.Value.Navn</h5>
                                <span class="badge bg-success">@item.Value.Antal på lager</span>
                            </div>

                            <p class="card-text text-muted flex-grow-1">@item.Value.Beskrivelse</p>

                            <div class="d-flex gap-2 mt-3">
                                <a class="btn btn-outline-primary btn-sm" asp-page="Opdater" asp-route-id="@item.Key">Opdater</a>
                                <a class="btn btn-outline-danger btn-sm" asp-page="Slet" asp-route-id="@item.Key">Slet</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            Der er ingen ingredienser endnu.
        </div>
    }
</div>
