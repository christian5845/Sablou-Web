@page
@model Sablou_Web.Pages.VoresChokoladerModel
@using Sablou_Web.Models
@{
    var cartFeedback = TempData["CartFeedback"] as string;
}

<style>
    .vh-wrap {
        font-family: 'Poiret One', cursive;
        background: #faf7f2;
        padding: 0;
        margin: -1rem;
    }

    .vh-hero {
        background: #3d1f0d;
        color: #f5e6d3;
        padding: 2.5rem 2rem 2rem;
        text-align: center;
        border-bottom: 3px solid #8B4513;
        position: relative;
        overflow: hidden;
    }

        .vh-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient( 45deg, transparent, transparent 30px, rgba(139, 69, 19, 0.08) 30px, rgba(139, 69, 19, 0.08) 31px );
        }

    .vh-hero-inner {
        position: relative;
        z-index: 1;
    }

    .vh-hero-brand {
        font-family: 'Poiret One', cursive;
        font-size: 1.5rem;
        color: #d4956a;
        letter-spacing: 1px;
        margin-bottom: 0.25rem;
    }

    .vh-hero h1 {
        font-size: 2rem;
        margin: 0 0 0.4rem;
        font-weight: 400;
        letter-spacing: 2px;
    }

    .vh-hero p {
        font-size: 0.95rem;
        color: #d4956a;
        margin: 0;
        font-family: sans-serif;
        font-style: italic;
    }

    .vh-intro {
        background: #fff;
        border-bottom: 1px solid #e8ddd0;
        padding: 1.25rem 2rem;
        text-align: center;
        color: #666;
        font-family: sans-serif;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .cart-feedback {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1rem 2rem 0;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #e8fff1, #d9fbe8);
        color: #14532d;
        border: 1px solid #86efac;
        box-shadow: 0 10px 26px rgba(20, 83, 45, 0.12);
        font-weight: 700;
        font-family: sans-serif;
    }

    .cart-feedback-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #16a34a;
        color: white;
        flex: 0 0 auto;
        box-shadow: 0 8px 18px rgba(22, 163, 74, 0.25);
    }

    .cart-feedback-text {
        flex: 1;
    }

    .vh-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
        padding: 1.5rem;
    }

    .vh-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e0d0c0;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(61, 31, 13, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .vh-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(61, 31, 13, 0.12);
        }

    .vh-card-top {
        padding: 1.25rem 1.25rem 1rem;
        text-align: center;
        border-bottom: 1px solid #f0e4d4;
    }

    .product-media {
        position: relative;
        overflow: hidden;
        border-radius: 10px;
        background: linear-gradient(135deg, #f7e7db, #fff);
        margin-bottom: 1rem;
        width: 100%;
        height: 240px;
        display: flex;
        align-items: stretch;
    }

    .product-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transform: scale(1);
        transition: transform 0.35s ease;
    }

    .vh-card:hover .product-media img {
        transform: scale(1.03);
    }

    .product-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.88);
        color: #3d1f0d;
        font-size: 0.8rem;
        font-weight: 800;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.8);
        font-family: sans-serif;
    }

    .product-title {
        margin: 0 0 0.35rem;
        font-size: 1.3rem;
        line-height: 1.2;
        font-weight: 400;
        letter-spacing: 1.5px;
        color: #3d1f0d;
    }

    .product-description {
        margin: 0 0 0.85rem;
        color: #666;
        line-height: 1.6;
        min-height: 4.8rem;
        font-family: sans-serif;
        font-size: 0.85rem;
    }

    .product-price {
        margin: 0 0 1rem;
        font-size: 1rem;
        font-weight: 700;
        color: #8B4513;
    }

    .product-actions {
        padding: 1rem 1.25rem 1.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .details-btn,
    .add-to-cart-btn {
        width: 100%;
        border-radius: 999px;
        padding: 0.6rem 1rem;
        font-family: 'Poiret One', cursive;
        font-size: 0.95rem;
        letter-spacing: 1px;
        border: none;
        text-align: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        box-sizing: border-box;
        text-decoration: none;
        font-weight: 700;
    }

    .details-btn:hover,
    .add-to-cart-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.03);
    }

    .details-btn {
        background: #fff7ea;
        color: #3d1f0d;
        border: 1px solid #e0d0c0;
        box-shadow: 0 4px 12px rgba(61, 31, 13, 0.08);
    }

        .details-btn:hover {
            color: #3d1f0d;
            text-decoration: none;
            box-shadow: 0 8px 18px rgba(61, 31, 13, 0.12);
        }

    .add-to-cart-form {
        margin: 0;
        flex: 1 1 10rem;
    }

    .add-to-cart-btn {
        box-shadow: 0 4px 12px rgba(25, 135, 84, 0.18);
    }

        .add-to-cart-btn:hover {
            box-shadow: 0 8px 18px rgba(25, 135, 84, 0.24);
        }

    .site-footer {
        position: relative;
        background: #3d1f0d;
        color: #f5e6d3;
        padding: 1.8rem 1rem;
        text-align: center;
        font-size: 0.95rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin-top: 2rem;
        font-family: sans-serif;
    }

    .site-footer a {
        color: #f5e6d3;
        text-decoration: underline;
        opacity: 0.9;
    }

    .footer-links {
        margin-top: 0.7rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        font-size: 0.95rem;
        flex-wrap: wrap;
    }

    .instagram-icon-link {
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        line-height: 0;
    }

    .instagram-icon-link img {
        width: 38px;
        height: 38px;
        object-fit: contain;
        display: block;
        transition: transform 0.3s ease;
    }

    .instagram-icon-link img:hover {
        transform: scale(1.12);
    }

    .footer-links a {
        color: inherit;
        text-decoration: none;
    }

    .footer-links a:hover {
        text-decoration: underline;
    }

    @@media (max-width: 768px) {
        .vh-hero h1 {
            font-size: 1.5rem;
        }

        .vh-grid {
            grid-template-columns: 1fr;
            padding: 1rem;
        }

        .vh-intro,
        .cart-feedback {
            margin-left: 1rem;
            margin-right: 1rem;
        }

        .product-description {
            min-height: auto;
        }
    }
</style>

<div class="vh-wrap">

    <div class="vh-hero">
        <div class="vh-hero-inner">
            <div class="vh-hero-brand">Sabloú</div>
            <h1>Vores chokolader</h1>
            <p>Udvalgte chokolader med fokus på smag, kvalitet og sæsonens favoritter</p>
        </div>
    </div>

    <div class="vh-intro">
        Udforsk vores kollektion af håndlavede chokolader — skabt med omtanke, detaljer og en forkærlighed for det elegante.
    </div>

    @if (!string.IsNullOrWhiteSpace(cartFeedback))
    {
        <div class="cart-feedback" role="status" aria-live="polite">
            <span class="cart-feedback-icon">✓</span>
            <span class="cart-feedback-text">@cartFeedback</span>
        </div>
    }

    <div class="vh-grid">
        @foreach (var c in Model.Repo.ChokoladeRepository.Data.Values)
        {
            var lowerName = c.Navn.ToLowerInvariant();
            var hasSummer = lowerName.Contains("sommer");
            var hasChristmas = lowerName.Contains("jul");
            var hasEaster = lowerName.Contains("påske");
            var hasDubai = lowerName.Contains("dubai");
            var hasMarcipan = lowerName.Contains("marcipan");

            <article class="vh-card">
                <div class="vh-card-top">
                    @if (hasSummer)
                    {
                        <span class="product-badge">Sommerfavorit</span>
                        <div class="product-media">
                            <img src="~/Images/Sommerchokolade.png" alt="@c.Navn" />
                        </div>
                    }
                    else if (hasChristmas)
                    {
                        <span class="product-badge">Julechokolade</span>
                        <div class="product-media">
                            <img src="~/Images/Julechokolade.png" alt="@c.Navn" />
                        </div>
                    }
                    else if (hasEaster)
                    {
                        <span class="product-badge">Påskefavorit</span>
                        <div class="product-media">
                            <img src="~/Images/Påskechokolade.png" alt="@c.Navn" />
                        </div>
                    }
                    else if (hasDubai)
                    {
                        <span class="product-badge">Dubai Special</span>
                        <div class="product-media">
                            <img src="~/Images/DubaiChokolade.png" alt="@c.Navn" />
                        </div>
                    }
                    else if (hasMarcipan)
                    {
                        <span class="product-badge">Marcipan Delight</span>
                        <div class="product-media">
                            <img src="~/Images/MarcipanChokolade.png" alt="@c.Navn" />
                        </div>
                    }
                    else
                    {
                        <div class="product-media">
                            <img src="~/Images/Sommerchokolade.png" alt="@c.Navn" />
                        </div>
                    }

                    <h2 class="product-title">@c.Navn</h2>
                    <p class="product-description">@c.Beskrivelse</p>
                    <p class="product-price">Pris: @c.VisPris()</p>
                </div>

                <div class="product-actions">
                    <a class="btn btn-primary btn-sm details-btn"
                       title="Kig nærmere"
                       asp-page="/Produktside"
                       asp-route-id="@c.Id">
                        Kig nærmere
                    </a>

                    <form method="post" asp-page="/VoresChokolader" asp-page-handler="TilføjTilKurv" class="add-to-cart-form">
                        <input type="hidden" name="chokoladeId" value="@c.Id" />
                        <button type="submit" class="btn btn-sm btn-success add-to-cart-btn">🛒 Læg i kurv</button>
                    </form>
                </div>
            </article>
        }
    </div>

</div>
