@page
@model Sablou_Web.Pages.VoresChokoladerModel
@using Sablou_Web.Models
@{
    var cartFeedback = TempData["CartFeedback"] as string;
}

<style>
    :root {
        --bg: #fff8f2;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --text: #2b1d16;
        --muted: #6f5b51;
        --brand: #8a4b2a;
        --brand-2: #c98b62;
        --accent: #16a34a;
        --border: rgba(138, 75, 42, 0.12);
        --shadow: 0 18px 40px rgba(69, 38, 22, 0.12);
    }

    body {
        background-color: #faf7f2;
        color: var(--text);
    }

    .page-shell {
        padding: 2rem 1rem 1rem;
    }

    .page-hero {
        background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,248,242,0.9));
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        padding: 1.4rem 1.5rem;
        margin: 0 0 1.25rem;
        backdrop-filter: blur(10px);
    }

    .page-hero h1 {
        margin: 0;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text);
    }

    .page-hero p {
        margin: 0.45rem 0 0;
        color: var(--muted);
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: 1.25rem;
        padding: 0;
    }

    .product {
        position: relative;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 1rem;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .product:hover {
        transform: translateY(-4px);
        border-color: rgba(138, 75, 42, 0.2);
        box-shadow: 0 24px 50px rgba(69, 38, 22, 0.16);
    }

    .product-media {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        background: linear-gradient(135deg, #f7e7db, #fff);
        margin-bottom: 1rem;
        min-height: 300px;
        display: flex;
        align-items: stretch;
    }

    .product-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scale(1);
        transition: transform 0.35s ease;
    }

    .product:hover .product-media img {
        transform: scale(1.03);
    }

    .product-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.88);
        color: var(--brand);
        font-size: 0.8rem;
        font-weight: 800;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.8);
    }

    .product-title {
        margin: 0 0 0.35rem;
        font-size: 1.35rem;
        line-height: 1.2;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
    }

    .product-description {
        margin: 0 0 0.85rem;
        color: var(--muted);
        line-height: 1.6;
        min-height: 4.8rem;
    }

    .product-price {
        margin: 0 0 1rem;
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--brand);
    }

    .product-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
    }

    .details-btn {
        border-radius: 999px;
        padding: 0.7rem 1rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(13, 110, 253, 0.14);
    }

    .details-btn:hover {
        transform: translateY(-1px);
    }

    .add-to-cart-form {
        margin: 0;
    }

    .add-to-cart-btn {
        transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease, filter 0.15s ease;
        min-width: 11rem;
        font-weight: 800;
        border-radius: 999px;
        box-shadow: 0 8px 18px rgba(25, 135, 84, 0.18);
    }

    .add-to-cart-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.03);
        box-shadow: 0 12px 24px rgba(25, 135, 84, 0.24);
    }

    .add-to-cart-btn.is-animating {
        animation: cart-success-pulse 520ms ease-out;
    }

    .add-to-cart-btn.is-loading {
        transform: scale(0.97);
        box-shadow: 0 0 0 0.25rem rgba(15, 157, 88, 0.24), 0 8px 18px rgba(15, 157, 88, 0.25);
        background-color: #0f9d58;
        border-color: #0f9d58;
        color: white;
    }

    .add-to-cart-btn.is-loading::after {
        content: "";
        display: inline-block;
        width: 0.85rem;
        height: 0.85rem;
        margin-left: 0.55rem;
        border: 2px solid rgba(255,255,255,0.55);
        border-top-color: white;
        border-radius: 50%;
        animation: cart-spinner 0.8s linear infinite;
        vertical-align: -0.12rem;
    }

    .cart-feedback {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1rem 0 1.25rem;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #e8fff1, #d9fbe8);
        color: #14532d;
        border: 1px solid #86efac;
        box-shadow: 0 10px 26px rgba(20, 83, 45, 0.12);
        font-weight: 700;
        animation: cart-feedback-in 180ms ease-out, cart-feedback-glow 1.4s ease-in-out infinite;
    }

    .cart-feedback-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #16a34a;
        color: white;
        flex: 0 0 auto;
        box-shadow: 0 8px 18px rgba(22, 163, 74, 0.25);
    }

    .cart-feedback-text {
        flex: 1;
    }

    .site-footer {
        position: relative;
        background: #0f1720;
        color: #e6eef8;
        padding: 2rem 1rem;
        text-align: center;
        font-size: 0.95rem;
        border-top: 1px solid rgba(255,255,255,0.04);
        margin-top: 2rem;
    }

    .site-footer a {
        color: #e6eef8;
        text-decoration: underline;
        opacity: 0.9;
    }

    .footer-links {
        margin-top: 0.7rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        font-size: 0.95rem;
        flex-wrap: wrap;
    }

    .instagram-icon-link {
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        line-height: 0;
    }

    .instagram-icon-link img {
        width: 38px;
        height: 38px;
        object-fit: contain;
        display: block;
        transition: transform 0.3s ease;
    }

    .instagram-icon-link img:hover {
        transform: scale(1.12);
    }

    .footer-links a {
        color: inherit;
        text-decoration: none;
    }

    .footer-links a:hover {
        text-decoration: underline;
    }

    @@keyframes cart-feedback-in {
        from {
            opacity: 0;
            transform: translateY(-6px) scale(0.99);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes cart-feedback-glow {
        0%, 100% {
            box-shadow: 0 10px 26px rgba(20, 83, 45, 0.12);
        }

        50% {
            box-shadow: 0 12px 30px rgba(20, 83, 45, 0.18);
        }
    }

    @@keyframes cart-success-pulse {
        0% { transform: scale(1); }
        40% { transform: scale(1.03); }
        100% { transform: scale(1); }
    }

    @@keyframes cart-spinner {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 576px) {
        .page-shell {
            padding: 1rem 0.75rem 0;
        }

        .page-hero {
            padding: 1rem 1rem 1.1rem;
            border-radius: 20px;
        }

        .product {
            padding: 0.85rem;
            border-radius: 20px;
        }

        .product-media {
            min-height: 240px;
        }

        .product-title {
            font-size: 1.2rem;
        }

        .product-description {
            min-height: auto;
        }

        .details-btn,
        .add-to-cart-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<main class="page-content container page-shell">
    <section class="page-hero">
        <h1>Vores Chokolader</h1>
        <p>Udvalgte chokolader med fokus på smag, kvalitet og sæsonens favoritter.</p>
    </section>

    @if (!string.IsNullOrWhiteSpace(cartFeedback))
    {
        <div class="cart-feedback" role="status" aria-live="polite">
            <span class="cart-feedback-icon">✓</span>
            <span class="cart-feedback-text">@cartFeedback</span>
        </div>
    }

    <div class="product-grid">
        @foreach (var c in Model._repo.ChokoladeRepository.Data.Values)
        {
            var lowerName = c.Navn.ToLowerInvariant();
            var hasSummer = lowerName.Contains("sommer");
            var hasChristmas = lowerName.Contains("jul");
            var hasEaster = lowerName.Contains("påske");

            <article class="product">
                <div class="product-media">
                    @if (hasSummer)
                    {
                        <span class="product-badge">Sommerfavorit</span>
                        <img src="~/Images/Sommerchokolade.png" alt="@c.Navn"
                             style="width:100%; height:300px; object-fit:cover;" />
                    }
                    else if (hasChristmas)
                    {
                        <span class="product-badge">Julechokolade</span>
                        <img src="~/Images/Julechokolade.png" alt="@c.Navn"
                             style="width:100%; height:300px; object-fit:cover;" />
                    }
                    else if (hasEaster)
                    {
                        <span class="product-badge">Påskefavorit</span>
                        <img src="~/Images/Påskechokolade.png" alt="@c.Navn"
                             style="width:100%; height:300px; object-fit:cover;" />
                    }
                </div>

                <h2 class="product-title">@c.Navn</h2>
                <p class="product-description">@c.Beskrivelse</p>
                <p class="product-price">Pris: @c.VisPris()</p>

                <div class="product-actions">
                    <a class="btn btn-primary btn-sm details-btn"
                       title="Kig nærmere"
                       asp-page="/Produktside"
                       asp-route-id="@c.Id">
                        Kig nærmere
                    </a>

                    <form method="post" asp-page="/VoresChokolader" asp-page-handler="TilføjTilKurv" class="add-to-cart-form">
                        <input type="hidden" name="chokoladeId" value="@c.Id" />
                        <button type="submit" class="btn btn-sm btn-success add-to-cart-btn">🛒 Læg i kurv</button>
                    </form>
                </div>
            </article>
        }
    </div>
</main>

<footer class="site-footer" role="contentinfo">
    <div>
        © @DateTime.Now.Year Sablou — All rights reserved.
    </div>

    <div class="footer-links">
        <a href="https://www.instagram.com/sablou_cph/?hl=da"
           target="_blank"
           class="instagram-icon-link">
            <img src="~/images/insta.png" alt="Instagram" />
        </a>

        <span>·</span>

        <a href="/om">Om os</a>
    </div>
</footer>

